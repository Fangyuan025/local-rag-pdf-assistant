# Local data + artifacts
chroma_db/
data/uploads/
eval_results/
models/*.gguf

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# IDE
.vscode/
.idea/
.DS_Store

# Runtime logs
*.log

# Frontend build artefacts (web/.gitignore also covers these, but be
# explicit so a stray git-add at the repo root doesn't slip them in).
web/node_modules/
web/dist/
web/.vite/
web/*.log

